 "integrity_diagnosis": {
  "symptom": "adjacent ledger rows written in swapped order with intact hash chain",
  "mechanism_hypothesis": "hash-chain computation and file append are not atomic under concurrent tool execution inside one seat turn; the busier new-generation turns (workflow notices give approver/application seats real turns with parallel tool calls) exposed the latent race",
  "evidence": [
   "r1_control ordinals 392-395: emp-M defer_or_hold rows with timestamps 59.150/59.154/59.152 — chain order 392->394->393->395 is fully linked",
   "r1_clarify ordinals 403-406: chat_message .264 -> inbox_delivered .266 written before customer_contact .265 — same adjacent swap",
   "both R4 runs (also workflow-enabled) have fully valid chains: the race is timing-dependent, not deterministic"
  ],
  "proposed_fix": "serialize recorder ledger appends (single lock around chain-hash computation plus write); zero measurement-semantics change"
 },
